# Clarive — Configuration
# Copy to .env and edit. Only lines marked REQUIRED need changing.
# Run ./scripts/setup.sh to generate this automatically.

# ── Database ──
POSTGRES_USER=clarive
POSTGRES_PASSWORD=changeme                          # REQUIRED
POSTGRES_DB=clarive

# ── Authentication ──
JWT_SECRET=changeme-minimum-32-characters-long      # REQUIRED

# ── Encryption ──
CONFIG_ENCRYPTION_KEY=changeme-base64-32-byte-key   # REQUIRED

# ── AI (optional — leave blank to disable AI features) ──
OPENAI_API_KEY=
AI_DEFAULT_MODEL=gpt-4o-mini
AI_PREMIUM_MODEL=gpt-4o
TAVILY_API_KEY=                                    # Optional — enables web search during AI generation

# ── Google OAuth (optional) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VITE_GOOGLE_CLIENT_ID=

# ── URLs ──
CORS_ORIGINS=http://localhost:8080
VITE_API_URL=http://localhost:5000

# ── Ports ──
FRONTEND_PORT=8080
BACKEND_PORT=5000

# ── Email (optional — defaults to console/log output) ──
EMAIL_PROVIDER=console
EMAIL_API_KEY=
EMAIL_FROM_ADDRESS=noreply@localhost
EMAIL_FROM_NAME=Clarive

# ── Version (pin to a specific release, or use "latest") ──
CLARIVE_VERSION=latest
