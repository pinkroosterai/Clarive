{
  "ConnectionStrings": {
    "DefaultConnection": "",
    "Valkey": ""
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "Clarive",
    "Audience": "Clarive",
    "ExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{TraceId:l}] {SourceContext}{NewLine}  {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithCorrelationId"
    ]
  },
  "App": {
    "FrontendUrl": "http://localhost:8080",
    "AllowRegistration": "true"
  },
  "Email": {
    "Provider": "none",
    "ApiKey": "",
    "FromAddress": "noreply@clarive.app",
    "FromName": "Clarive"
  },
  "Google": {
    "ClientId": "",
    "ClientSecret": ""
  },
  "Ai": {
    "DefaultModel": "gpt-4o-mini",
    "PremiumModel": "gpt-4o"
  },
  "RateLimiting": {
    "PermitLimit": 20,
    "StrictPermitLimit": 5,
    "PublicApiPermitLimit": 600,
    "PublicApiWindowMinutes": 1
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:8080"]
  },
  "AllowedHosts": "*"
}
