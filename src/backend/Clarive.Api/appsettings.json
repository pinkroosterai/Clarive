{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "Clarive",
    "Audience": "Clarive",
    "ExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}{NewLine}  {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/clarive-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "fileSizeLimitBytes": 52428800,
          "rollOnFileSizeLimit": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] [Thread:{ThreadId}] [Machine:{MachineName}] [Request:{RequestId}] [Path:{RequestPath}] [User:{UserId}] [Tenant:{TenantId}] [Role:{UserRole}]{NewLine}  {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/errors-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "restrictedToMinimumLevel": "Error",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] [Thread:{ThreadId}] [User:{UserId}] [Tenant:{TenantId}]{NewLine}  {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "App": {
    "FrontendUrl": "http://localhost:8080"
  },
  "Email": {
    "Provider": "none",
    "ApiKey": "",
    "FromAddress": "noreply@clarive.app",
    "FromName": "Clarive"
  },
  "Google": {
    "ClientId": "",
    "ClientSecret": ""
  },
  "Ai": {
    "OpenAiApiKey": "",
    "EndpointUrl": "",
    "DefaultModel": "gpt-5-mini",
    "PremiumModel": "gpt-5.2"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:8080"]
  },
  "AllowedHosts": "*"
}
