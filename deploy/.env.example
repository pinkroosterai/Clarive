# Clarive — Build-from-source Configuration
#
# Full configuration for deploying Clarive built from source.
#
# Setup:
#   cp deploy/.env.example deploy/.env
#   # Fill in the CHANGE_ME values (generation commands provided)
#   make deploy
#
# Or run: make setup (auto-generates secrets)
#
# See docs/configuration.md for details on each variable.

# ── Database ──
POSTGRES_USER=clarive
POSTGRES_DB=clarive

# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME

# ── Authentication ──
# Generate: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_minimum_32_characters_long_for_hmac_sha256
JWT_ISSUER=Clarive
JWT_AUDIENCE=Clarive

# ── Encryption ──
# Generate: openssl rand -base64 32
CONFIG_ENCRYPTION_KEY=CHANGE_ME_base64_encoded_32_byte_key

# ── ASP.NET ──
ASPNETCORE_ENVIRONMENT=Production

# ── Application ──
CORS_ORIGINS=https://your-domain.example.com
ALLOW_REGISTRATION=true

# ── Port & Image Tag ──
CLARIVE_PORT=8080
CLARIVE_TAG=latest

# ── AI Service (optional — AI features disabled if blank) ──
OPENAI_API_KEY=
AI_ENDPOINT_URL=
AI_DEFAULT_MODEL=gpt-4o-mini
AI_PREMIUM_MODEL=gpt-4o

# ── Google OAuth (optional) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VITE_GOOGLE_CLIENT_ID=

# ── Email ──
# Provider: none | console | resend | smtp
#   none    — no emails sent, new users auto-verified (default)
#   console — logs emails to stdout (for development)
#   resend  — sends via Resend API
#   smtp    — sends via SMTP server
EMAIL_PROVIDER=none

# Resend settings (only when EMAIL_PROVIDER=resend)
EMAIL_API_KEY=

# SMTP settings (only when EMAIL_PROVIDER=smtp)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_USE_TLS=true

# Sender settings (required for resend and smtp)
EMAIL_FROM_ADDRESS=noreply@your-domain.example.com
EMAIL_FROM_NAME=Clarive

# ── Rate Limiting ──
RATE_LIMIT_STRICT=5
