# Clarive — Production Environment Configuration
#
# Copy to deploy/.env and fill in the values:
#   cp deploy/.env.example deploy/.env
#
# Or run: make setup
#
# See docs/configuration.md for details on each variable.

# ── Database ──
POSTGRES_USER=clarive
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=clarive

# ── ASP.NET ──
ASPNETCORE_ENVIRONMENT=Production

# ── Authentication ──
JWT_SECRET=CHANGE_ME_minimum_32_characters_long_for_hmac_sha256
JWT_ISSUER=Clarive
JWT_AUDIENCE=Clarive

# ── AI Service (optional — AI features disabled if blank) ──
OPENAI_API_KEY=
AI_ENDPOINT_URL=
AI_DEFAULT_MODEL=gpt-4o-mini
AI_PREMIUM_MODEL=gpt-4o

# ── Google OAuth (optional) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VITE_GOOGLE_CLIENT_ID=

# ── Application ──
CORS_ORIGINS=https://your-domain.example.com
VITE_API_URL=/api

# ── Email ──
# Provider: none | console | resend | smtp
#   none    — no emails sent, new users auto-verified (default)
#   console — logs emails to stdout (for development)
#   resend  — sends via Resend API
#   smtp    — sends via SMTP server
EMAIL_PROVIDER=none

# Resend settings (only when EMAIL_PROVIDER=resend)
EMAIL_API_KEY=

# SMTP settings (only when EMAIL_PROVIDER=smtp)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_USE_TLS=true

# Sender settings (required for resend and smtp)
EMAIL_FROM_ADDRESS=noreply@your-domain.example.com
EMAIL_FROM_NAME=Clarive

# ── Encryption ──
CONFIG_ENCRYPTION_KEY=CHANGE_ME_base64_encoded_32_byte_key
