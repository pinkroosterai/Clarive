# Clarive — Environment Configuration
# Copy this file to deploy/envs/<env>.env and fill in the values.
# See docs/configuration.md for details on each variable.

# ── Database ──
POSTGRES_USER=clarive
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=clarive

# ── ASP.NET ──
ASPNETCORE_ENVIRONMENT=Production

# ── Authentication ──
JWT_SECRET=CHANGE_ME_minimum_32_characters_long_for_hmac_sha256
JWT_ISSUER=Clarive
JWT_AUDIENCE=Clarive

# ── AI Service (optional — AI features disabled if blank) ──
OPENAI_API_KEY=
AI_DEFAULT_MODEL=gpt-4o-mini
AI_PREMIUM_MODEL=gpt-4o

# ── Google OAuth (optional) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VITE_GOOGLE_CLIENT_ID=

# ── Application ──
CORS_ORIGINS=https://your-domain.example.com
VITE_API_URL=/api

# ── Sentry / Error Tracking (optional) ──
SENTRY_DSN=
SENTRY_BACKEND_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_RELEASE=

# ── Email (optional — defaults to console logging) ──
EMAIL_PROVIDER=console
EMAIL_API_KEY=
EMAIL_FROM_ADDRESS=noreply@your-domain.example.com
EMAIL_FROM_NAME=Clarive

# ── Encryption ──
CONFIG_ENCRYPTION_KEY=CHANGE_ME_base64_encoded_32_byte_key
