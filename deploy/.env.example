# Clarive — Build-from-source Configuration
#
# Infrastructure secrets only. All application settings (AI, Email, Auth, etc.)
# are configured via Super Admin > Settings after first login.
#
# Setup:
#   cp deploy/.env.example deploy/.env
#   # Fill in the CHANGE_ME values (generation commands provided)
#   make deploy
#
# Or run: make setup (auto-generates secrets)

# ── Database ──
POSTGRES_USER=clarive
POSTGRES_DB=clarive

# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME

# ── Authentication ──
# Generate: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_minimum_32_characters_long_for_hmac_sha256

# ── Encryption ──
# Generate: openssl rand -base64 32
CONFIG_ENCRYPTION_KEY=CHANGE_ME_base64_encoded_32_byte_key

# ── ASP.NET ──
ASPNETCORE_ENVIRONMENT=Production

# ── Network ──
CORS_ORIGINS=https://your-domain.example.com

# ── Port & Image Tag ──
CLARIVE_PORT=8080
CLARIVE_TAG=latest
